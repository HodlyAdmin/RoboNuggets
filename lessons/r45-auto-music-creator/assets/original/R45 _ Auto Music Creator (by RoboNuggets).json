      "parameters": {
        "content": "# Auto Music Creator\n# (by RoboNuggets)\n## Author: Jay E | R45\n\n# Step 2: Create Music",
        "height": 272,
        "width": 704,
        "color": 6
      },
      "type": "n8n-nodes-base.stickyNote",
