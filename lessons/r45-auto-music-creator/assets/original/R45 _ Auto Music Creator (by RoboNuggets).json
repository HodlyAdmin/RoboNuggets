    {
      "parameters": {
        "jsCode": "// Get image from 'Check' node\nconst imagePath = $('Check Img').first().json.file_info.file_path;\n\n// Get all song paths from the current input\nconst songs = $input.first().json.file_info.map(f => f.file_path);\n\n// Build filter_complex dynamically based on song count\nconst concatInputs = songs.map((_, i) => `[${i + 1}:a]`).join('');\nconst filterComplex = `${concatInputs}concat=n=${songs.length}:v=0:a=1[aout];[0:v]loop=999:size=1:start=0,scale=1280:720,setpts=N/FRAME_RATE/TB[vout]`;\n\n// Construct the ffmpeg_job object\nreturn {\n  ffmpeg_job: {\n    task: {\n      inputs: [\n        { file_path: imagePath },\n        ...songs.map(file => ({ file_path: file }))\n      ],\n      filter_complex: filterComplex,\n      outputs: [\n        {\n          file: 'final-video.mp4',\n          options: ['-map', '[vout]', '-map', '[aout]', '-c:v', 'libx264', '-crf', '23', '-c:a', 'aac'],\n          maps: []\n        }\n      ]\n    }\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        448
      ],
